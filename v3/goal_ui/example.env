# Supabase Configuration
# For manual setup, get these from your Supabase project settings
# (Dashboard → Project Settings → API)

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key-here
VITE_SUPABASE_PROJECT_ID=your-project-id

# Supabase Secrets (Server-side only - DO NOT expose in frontend)
# Configure these in Supabase Dashboard → Project Settings → Edge Functions → Secrets
#
# AI_GATEWAY_URL=URL of any OpenAI-compatible /v1/chat/completions endpoint you control
# AI_GATEWAY_API_KEY=Bearer token for the gateway above
#
# SUPABASE_URL=auto-provided by Supabase runtime
# SUPABASE_ANON_KEY=auto-provided by Supabase runtime
# SUPABASE_SERVICE_ROLE_KEY=auto-provided - keep secret
# SUPABASE_DB_URL=auto-provided by Supabase runtime
# SUPABASE_PUBLISHABLE_KEY=auto-provided by Supabase runtime
