{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": "node .cursor/hooks/cursor-hook-handler.cjs pre-bash",
        "timeout": 5,
        "failClosed": false
      }
    ],
    "afterFileEdit": [
      {
        "command": "node .cursor/hooks/cursor-hook-handler.cjs post-edit",
        "timeout": 10,
        "failClosed": false
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "node .cursor/hooks/cursor-hook-handler.cjs route",
        "timeout": 10,
        "failClosed": false
      }
    ],
    "sessionStart": [
      {
        "command": "node .cursor/hooks/cursor-hook-handler.cjs session-restore",
        "timeout": 15,
        "failClosed": false
      },
      {
        "command": "node .cursor/hooks/cursor-memory-hook.cjs import",
        "timeout": 8,
        "failClosed": false
      }
    ],
    "stop": [
      {
        "command": "node .cursor/hooks/cursor-memory-hook.cjs sync",
        "timeout": 10,
        "failClosed": false,
        "loop_limit": null
      }
    ],
    "preCompact": [
      {
        "command": "node .cursor/hooks/cursor-hook-handler.cjs compact-manual",
        "timeout": 5,
        "failClosed": false
      }
    ],
    "subagentStop": [
      {
        "command": "node .cursor/hooks/cursor-hook-handler.cjs post-task",
        "timeout": 5,
        "failClosed": false,
        "loop_limit": null
      }
    ]
  }
}
